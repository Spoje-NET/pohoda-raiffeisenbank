                "en": "for multicurrency accounts please specify one",
                "cs": "U víceměnových účtů prosím zadejte měnu"
            },
            "defval": "",
            "hint": {
                "en": "CZK",
                "cs": "CZK"
            },
            "required": false,
            "category": "Other"
        },
